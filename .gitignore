prompts
*.log
*.key

# go build ./... writes a binary per main package into the repo root/cmd
# dirs unless -o is given; these are never meant to be committed.
/kvnode
/kvctl-cli
/cmd/kvnode/kvnode
/cmd/kvctl-cli/kvctl-cli

# pkg/e2erun's cross-compiled/native binaries for the e2e deploy pipeline.
/.e2e-build/

# Android app build outputs / local machine config (regenerated by gradle/gomobile)
android-app/app/build/
android-app/.gradle/
android-app/.kotlin/
android-app/local.properties
android-app/app/libs/

# web-app build outputs / dependencies (regenerated by npm/cargo/wasm-pack)
web-app/node_modules/
web-app/dist/
web-app/pkg/
web-app/target/
web-app/test-results/
web-app/playwright-report/